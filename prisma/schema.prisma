generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum WishlistStatus {
  AVAILABLE
  RESERVED
  PURCHASED
}

enum QuizScope {
  USER
  COUPLE
}

enum DateIdeaScope {
  GENERAL
  COUPLE
}

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String
  firstName    String
  lastName     String
  role         UserRole       @default(USER)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  coupleMembers CoupleMember[]
  refreshTokens RefreshToken[]
  quizResults   QuizResult[]
  orders        Order[]
  wishlistItems WishlistItem[]
}

model Couple {
  id          String         @id @default(uuid())
  name        String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  members     CoupleMember[]
  quizResults QuizResult[]
  dateIdeas   DateIdea[]
  wishlistItems WishlistItem[]
}

model CoupleMember {
  id        String   @id @default(uuid())
  coupleId  String
  userId    String
  role      String?
  createdAt DateTime @default(now())

  couple Couple @relation(fields: [coupleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([coupleId, userId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Quiz {
  id          String         @id @default(uuid())
  title       String
  description String?
  scope       QuizScope      @default(USER)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  questions   QuizQuestion[]
  results     QuizResult[]
}

model QuizQuestion {
  id        String       @id @default(uuid())
  quizId    String
  text      String
  order     Int
  options   QuizOption[]
  quiz      Quiz         @relation(fields: [quizId], references: [id])
}

model QuizOption {
  id          String       @id @default(uuid())
  questionId  String
  text        String
  value       String
  question    QuizQuestion @relation(fields: [questionId], references: [id])
}

model QuizResult {
  id        String   @id @default(uuid())
  quizId    String
  userId    String
  coupleId  String?
  answers   Json
  score     Json?
  createdAt DateTime @default(now())

  quiz   Quiz   @relation(fields: [quizId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  couple Couple? @relation(fields: [coupleId], references: [id])
}

model DateIdea {
  id          String       @id @default(uuid())
  title       String
  description String
  scope       DateIdeaScope @default(GENERAL)
  coupleId    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  tags        DateIdeaTag[]
  couple      Couple?      @relation(fields: [coupleId], references: [id])
}

model Tag {
  id    String       @id @default(uuid())
  name  String       @unique
  ideas DateIdeaTag[]
}

model DateIdeaTag {
  dateIdeaId String
  tagId      String

  dateIdea DateIdea @relation(fields: [dateIdeaId], references: [id])
  tag      Tag      @relation(fields: [tagId], references: [id])

  @@id([dateIdeaId, tagId])
}

model WishlistItem {
  id               String         @id @default(uuid())
  coupleId         String
  userId           String
  shopifyProductId String
  title            String
  imageUrl         String?
  price            Decimal        @db.Decimal(10,2)
  status           WishlistStatus @default(AVAILABLE)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  couple Couple @relation(fields: [coupleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

model Order {
  id              String   @id @default(uuid())
  userId          String
  shopifyOrderId  String
  totalAmount     Decimal  @db.Decimal(10,2)
  currency        String
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
